# ============================================================
# 仅“引导级”连接配置与部署密钥放在 .env。
# 业务可调参数全部在【配置中心】管理（入库），杜绝散落硬编码。
# ============================================================

# 运行环境
NODE_ENV=development
PORT=3000

# 数据库（PostgreSQL）—— 引导阶段必需
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=infra
DB_PASSWORD=infra_dev_pwd
DB_NAME=infra_platform
# 开发期允许 TypeORM 自动同步表结构；生产应改为 false 并使用迁移
DB_SYNCHRONIZE=true

# Redis —— 配置缓存 / WebSocket 适配
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT 部署密钥（属于凭据，与 DB 口令同级，不入配置中心）
JWT_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
